{
  "agentPushNotifEnabled": true,
  "effortLevel": "high",
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "document-skills@anthropic-agent-skills": true,
    "example-skills@anthropic-agent-skills": true,
    "figma@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_MONITOR_GHOSTTY_ASKED": "1",
    "DISABLE_ERROR_REPORTING": "1"
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/hook_validate_bash/check.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/hino/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$HOME/.claude/hooks/hook_stop_words/check.sh",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "includeCoAuthoredBy": false,
  "inputNeededNotifEnabled": true,
  "language": "Japanese",
  "model": "sonnet",
  "notificationChannel": "auto",
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": [
      "Read",
      "Skill(pr)",
      "Bash(npm run lint)",
      "Bash(npm run test)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run test)",
      "WebSearch",
      "mcp__sequential-thinking",
      "mcp__context7",
      "mcp__deepwiki",
      "mcp__plugin_claude-mem_mcp-search",
      "mcp__plugin_slack_slack__slack_read_channel",
      "mcp__plugin_slack_slack__slack_read_thread",
      "mcp__plugin_slack_slack__slack_read_canvas",
      "mcp__plugin_slack_slack__slack_read_user_profile",
      "mcp__plugin_slack_slack__slack_search_public",
      "mcp__plugin_slack_slack__slack_search_public_and_private",
      "mcp__plugin_slack_slack__slack_search_channels",
      "mcp__plugin_slack_slack__slack_search_users"
    ],
    "deny": [
      "Read(*.env*)",
      "Read(*.env)",
      "Read(*.env.local)",
      "Read(*.env.development)",
      "Read(*.env.production)",
      "Read(*.env.staging)",
      "Read(*.env.test)"
    ]
  },
  "plansDirectory": "./.claude/plans",
  "skipWorkflowUsageWarning": true,
  "statusLine": {
    "command": "sh $HOME/.claude/statusline.sh",
    "type": "command"
  },
  "teammateMode": "in-process",
  "terminalProgressBarEnabled": true,
  "theme": "dark-ansi",
  "tui": "default",
  "voiceEnabled": true
}